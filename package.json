{
  "name": "panorama",
  "version": "0.1.0",
  "description": "Panorama — a simulated glass window: head-tracked, off-axis 3D scenes.",
  "main": "./out/main/index.js",
  "author": "",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:web": "vite --config vite.web.config.ts",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "package": "electron-vite build && electron-builder --win portable",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.18",
    "electron-store": "^8.2.0",
    "three": "^0.169.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.169.0",
    "@vitejs/plugin-react": "^4.3.2",
    "electron": "^32.2.0",
    "electron-vite": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.3",
    "electron-builder": "^25.1.8",
    "vite": "^5.4.8",
    "vitest": "^2.1.2"
  },
  "build": {
    "appId": "com.panorama.window",
    "productName": "Panorama",
    "directories": { "output": "release" },
    "files": ["out/**/*"],
    "win": { "target": ["portable"] },
    "portable": { "artifactName": "Panorama.exe" }
  }
}
